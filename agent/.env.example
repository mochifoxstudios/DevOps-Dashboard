# DevOps Local Agent — environment configuration.
# Copy to .env and edit. .env is read on `npm start`.

# Port the agent listens on. The agent serves both the API and the frontend.
PORT=3737

# The single directory the agent is permitted to read from. All file/git operations
# are anchored here. A request that resolves outside this root is rejected.
# Use an absolute path. Defaults to the current working directory if unset.
WORKSPACE_ROOT=

# When true, destructive operations (file deletes, process kills, key rotations)
# are permitted after a confirm. When false (default), every destructive endpoint
# returns 403 regardless of confirm state. Keep false unless you trust the network.
ALLOW_DESTRUCTIVE=false

# Comma-separated list of additional env-var name patterns to redact in
# /api/context-snap/env. The defaults already cover SECRET, TOKEN, KEY,
# PASSWORD, PASSPHRASE, AUTH, CREDENTIAL, COOKIE, SESSION.
EXTRA_REDACT_PATTERNS=

# ---- Phase 3: Registry lookups ----
# When true (default), POST /api/dep-map/lookup contacts public registries
# (registry.npmjs.org, pypi.org, crates.io, proxy.golang.org, rubygems.org)
# to get the "latest" version for each dependency. Results are cached in
# memory for 15 minutes. Set to false for fully air-gapped operation.
REGISTRY_LOOKUP_ENABLED=true

# ---- Phase 3: Docs Scraper proxy ----
# Comma-separated list of hostnames the scraper is allowed to fetch.
# Supports exact match ("docs.stripe.com") and subdomain wildcard ("*.stripe.com").
# Empty list = deny all (the scraper is opt-in per host).
SCRAPER_ALLOWED_HOSTS=

# When true, the scraper bypasses the allowlist and accepts any public host.
# SSRF protection (private-IP refusal) still applies. Use only for trusted
# local development.
SCRAPER_ALLOW_ANY=false

# ---- Phase 5: LLM + GitHub closed-loop ----
# Comma-separated list of hostnames the LLM adapters are allowed to call.
# Default is the four supported providers + loopback. Tighten as needed.
LLM_ENDPOINT_ALLOWLIST=api.openai.com,api.anthropic.com,bedrock-runtime.us-east-1.amazonaws.com,localhost,127.0.0.1

# Audit log retention — how many rotated .audit-N.log files to keep.
AUDIT_KEEP=10

# Override GitHub API endpoint (used by smoke tests). Default api.github.com.
# GITHUB_ENDPOINT=https://api.github.com
